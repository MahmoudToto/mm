<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".Home">

    <!-- ══════════════════════════════════════════
         Header مع Toolbar + حالة الإنترنت
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="#1A237E"
        app:layout_constraintTop_toTopOf="parent">

        <!-- شعار صغير -->
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/mandopand"
            android:scaleType="centerCrop"
            android:contentDescription="logo" />

        <!-- العنوان -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="لوحة التحكم"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- مؤشر الإنترنت -->
        <ImageView
            android:id="@+id/internt"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/no_wifi"
            android:contentDescription="حالة الاتصال" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         المحتوى القابل للتمرير
         ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="64dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── بانر الترحيب ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A237E"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أهلاً بك 👋"
                    android:textColor="#90CAF9"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اختر ما تريد القيام به"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- ── منطقة البطاقات (ترتفع فوق البانر) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-16dp"
                android:background="#F0F4F8"
                android:paddingTop="16dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <!-- ══ صف 1 ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:weightSum="2">

                    <!-- بطاقة: العملاء -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_clients"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <!-- أيقونة ملونة -->
                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_blue"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/customer"
                                    android:contentDescription="العملاء" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="الطباعه"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · طباعة الايصالات ·"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- بطاقة: المنتجات -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_products"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_green"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_products"
                                    android:contentDescription="المنتجات" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="المنتجات"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1B5E20"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إضافة · تعديل · حذف"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ══ صف 2 ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:weightSum="2">

                    <!-- بطاقة: المخزن -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_inventory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_orange"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_store"
                                    android:contentDescription="المخزن" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="المخزن"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E65100"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إدارة المخزون"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- بطاقة: المندوبين -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_add_salesperson"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_purple"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_add_rep"
                                    android:contentDescription="المندوبين" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="المندوبين"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#4A148C"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إضافة · تعديل · حذف"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ══ صف 3 ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:weightSum="2">

                    <!-- بطاقة: المحصلين -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_collectors"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_teal"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_collectors"
                                    android:contentDescription="المحصلين" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="المحصلين"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#004D40"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إضافة · تعديل · حذف"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- بطاقة: تسليم التحصيل -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_deliver_collection"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_red"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_deliver"
                                    android:contentDescription="تسليم تحصيل" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="تسليم تحصيل"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#B71C1C"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="تسليم وتسوية"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ══ صف 4 ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:weightSum="2">

                    <!-- بطاقة: الإحصائيات -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statistics"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_indigo"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/statistics"
                                    android:contentDescription="الإحصائيات" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="الإحصائيات"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="تقارير وأرقام"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- بطاقة: التصفية -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_filter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="#FFFFFF">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_bg_brown"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_filter"
                                    android:contentDescription="تصفية" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="تصفية"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#3E2723"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="بحث وفلترة"
                                android:textSize="10sp"
                                android:textColor="#90A4AE"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ══ صف 5: بطاقة المستخدمين (عرض كامل) ══ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_users"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="#1A237E">

                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/circle_bg_white"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                android:contentDescription="المستخدمين" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إدارة المستخدمين"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إضافة · تعديل · حذف المستخدمين"
                                android:textSize="11sp"
                                android:textColor="#90CAF9"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/arrow_up_float"
                            android:rotation="90"
                            android:contentDescription="انتقال" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>